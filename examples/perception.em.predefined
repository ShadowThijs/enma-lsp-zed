// ============================================================================
// 13 - Zydis API
// ============================================================================

class zydis_req_t {
    void set_mnemonic(int64 mnemonic);
    void set_machine_mode(zydis_machine_mode mode);
    void set_operand_count(int64 count);
    void set_branch_type(zydis_branch_type type);
    void set_branch_width(zydis_branch_width width);
    void set_operand_reg(int64 idx, int64 reg);
    void set_operand_imm(int64 idx, int64 imm);
    void set_operand_mem(int64 idx, int64 base, int64 idx_reg, int64 scale, int64 disp, int64 size);
    void set_operand_ptr(int64 idx, int64 segment, int64 offset);
    int64 get_mnemonic();
    zydis_machine_mode get_machine_mode();
    int64 get_operand_count();
}

class zydis_builder_t {
    void set_machine_mode(zydis_machine_mode mode);
    void set_base_address(int64 addr);
    void clear();
    void push(zydis_req_t req);
    void push_bytes(array<uint8> bytes);
    void push_byte(uint8 b);
    void push_u16(uint16 v);
    void push_u32(uint32 v);
    void push_u64(uint64 v);
    void push_nop(int64 count);
    void push_int3();
    void push_ret();
    array<uint8> build();
    int64 get_count();
}

array<uint8> zydis_encode(zydis_req_t req);
array<uint8> zydis_encode_absolute(zydis_req_t req, int64 runtime_rip);
array<uint8> zydis_nop_fill(int64 length);
zydis_req_t zydis_decoded_to_request(array<uint8> bytes, int64 runtime_rip);

int64 zydis_mnemonic_from_string(string name);
string zydis_mnemonic_to_string(int64 mnemonic);
int64 zydis_register_from_string(string name);
string zydis_register_to_string(int64 reg);

array<string> zydis_disasm(array<uint8> bytes, int64 runtime_rip);

enum zydis_machine_mode {
    long_64,
    long_compat_32,
    long_compat_16,
    legacy_32,
    legacy_16,
    real_16,
}

enum zydis_branch_type {
    none,
    short,
    near,
    far,
}

enum zydis_branch_width {
    none,
    w8,
    w16,
    w32,
    w64,
}

