// Perception host API declarations.
// Loaded by the LSP from the workspace; not bundled with the stdlib.
// Mirrors the PDF docs at pcx-extended-api/03..13 with corrections from
// the OCR'd source and ground-truth example/*.em scripts.
// ----------------------------------------------------------------------------
// Anything already in enma-stdlib.em.predefined (array, map, vec2/3/4, quat,
// mat4, string, mutex etc.) is intentionally NOT redeclared here.

// ============================================================================
// 03 - Lifecycle and routines
// ============================================================================

int64 register_routine(int64 fn_handle, int64 data);
bool unregister_routine(int64 routine_handle);

void heartbeat();
void take_int(int64 x);
void take_ptr(int64 p);
void test_3arg(int64 a, int64 b, int64 c);

// Heavily used in every example script — log a line to perception's console.
void print_console(string msg);

// ============================================================================
// 04 - Proc API
// ============================================================================

class proc_t {
    // Identity
    uint64 base_address();
    uint64 peb();
    uint32 pid();
    bool alive();
    bool is_valid_address(uint64 addr);

    // Read primitives
    uint8 ru8(uint64 addr);
    uint16 ru16(uint64 addr);
    uint32 ru32(uint64 addr);
    uint64 ru64(uint64 addr);
    int8 r8(uint64 addr);
    int16 r16(uint64 addr);
    int32 r32(uint64 addr);
    int64 r64(uint64 addr);
    float32 rf32(uint64 addr);
    float64 rf64(uint64 addr);
    string rs(uint64 addr, int32 max_chars);
    string rws(uint64 addr, int32 max_chars);

    // Write primitives (gated: write_memory)
    bool wu8(uint64 addr, uint8 v);
    bool wu16(uint64 addr, uint16 v);
    bool wu32(uint64 addr, uint32 v);
    bool wu64(uint64 addr, uint64 v);
    bool w8(uint64 addr, int8 v);
    bool w16(uint64 addr, int16 v);
    bool w32(uint64 addr, int32 v);
    bool w64(uint64 addr, int64 v);
    bool wf32(uint64 addr, float32 v);
    bool wf64(uint64 addr, float64 v);
    bool ws(uint64 addr, string text);
    bool wws(uint64 addr, string text);

    // Bulk read/write
    array<uint8> rvm(uint64 addr, uint64 size);
    bool wvm(uint64 addr, array<uint8> bytes);

    // Typed vector / quaternion / matrix reads (gated: read_memory)
    vec2 read_vec2_fl32(uint64 addr);
    vec2 read_vec2_fl64(uint64 addr);
    vec3 read_vec3_fl32(uint64 addr);
    vec3 read_vec3_fl64(uint64 addr);
    vec4 read_vec4_fl32(uint64 addr);
    vec4 read_vec4_fl64(uint64 addr);
    quat read_quat_fl32(uint64 addr);
    quat read_quat_fl64(uint64 addr);
    mat4 read_mat4_fl32(uint64 addr);
    mat4 read_mat4_fl64(uint64 addr);

    // Typed vector / quaternion / matrix writes (gated: write_memory)
    bool write_vec2_fl32(uint64 addr, vec2 v);
    bool write_vec2_fl64(uint64 addr, vec2 v);
    bool write_vec3_fl32(uint64 addr, vec3 v);
    bool write_vec3_fl64(uint64 addr, vec3 v);
    bool write_vec4_fl32(uint64 addr, vec4 v);
    bool write_vec4_fl64(uint64 addr, vec4 v);
    bool write_quat_fl32(uint64 addr, quat q);
    bool write_quat_fl64(uint64 addr, quat q);
    bool write_mat4_fl32(uint64 addr, mat4 m);
    bool write_mat4_fl64(uint64 addr, mat4 m);

    // SIMD-width reads/writes
    array<uint8> r128(uint64 addr);
    array<uint8> r256(uint64 addr);
    array<uint8> r512(uint64 addr);
    bool w128(uint64 addr, array<uint8> bytes);
    bool w256(uint64 addr, array<uint8> bytes);
    bool w512(uint64 addr, array<uint8> bytes);

    // Modules and exports
    uint64 get_module_base(string name);
    uint64 get_module_size(string name);
    uint64 get_proc_address(uint64 module_base, string export_name);
    uint64 get_import_rdata_address(uint64 module_base, string import_name);

    // Pattern scanning
    uint64 find_code_pattern(uint64 search_start, uint64 search_size, string sig);
    array<uint64> find_all_code_patterns(uint64 search_start, uint64 search_size, string sig);

    // Threads
    array<uint64> get_all_tebs();

    // Pointer arrays
    array<uint64> read_pointer_array(uint64 base, int64 count, int64 offset_delta);

    // VAD / virtual_query
    vad_region_t virtual_query(uint64 address);
    array<vad_region_t> get_vad_snapshot(bool heap_likely_only);

    // Memory scans
    array<uint64> scan_string(string text, bool heap_only);
    array<uint64> scan_wstring(string text, bool heap_only);
    array<uint64> scan_pointer(uint64 target, bool heap_only);
    array<uint64> scan_u64(uint64 value, bool heap_only);
    array<uint64> scan_u32(uint32 value, bool heap_only);
    array<uint64> scan_float(float32 value, bool heap_only);
    array<uint64> scan_double(float64 value, bool heap_only);

    // VM alloc / free (gated: virtual_memory_operations)
    uint64 alloc_vm(uint64 size);
    bool free_vm(uint64 address);

    // Kernel pointer (gated: kernel_rw_access)
    uint64 get_eprocess();
}

class vad_region_t {
    uint64 start();
    uint64 size();
    uint64 protection();
    bool heap_likely();
}

proc_t ref_process(string name);
proc_t ref_process(uint32 pid);

// ============================================================================
// 05 - CPU API
// ============================================================================

string cpu_vendor();
string cpu_brand();

int64 rdtsc();
int64 perf_time();
int64 perf_frequency();
int64 get_tickcount64();

int64 now_millisecond();
string day_name(int64 dow);
string month_name(int64 month);
int64 hour12(int64 hour24);
string ampm(int64 hour24);

// Bit-pattern conversions are now done with reinterpret_cast<T>(val):
//   uint32 bits = reinterpret_cast<uint32>(1.5f);
//   float32 f   = reinterpret_cast<float32>(0x3FC00000u);
// The old bits_f32_to_u32 / bits_u32_to_f32 / bits_f64_to_u64 /
// bits_u64_to_f64 natives have been removed.

bool set_thread_priority(thread_priority p);

enum thread_priority {
    lowest,
    below_normal,
    normal,
    above_normal,
    highest,
    time_critical,
}

// ============================================================================
// 06 - GUI API
// ============================================================================

// --- enums ----------------------------------------------------------------

enum ui_align { left, center, right }
enum ui_anchor { none, left, right, top, bottom, all }
enum ui_edge { left, top, right, bottom }
enum ui_layout { none, vertical, horizontal }
enum keybind_mode { off, on, single, toggle, always_on }
enum toast_kind { info, success, warning, error }

// modular_ui color hashes (subset). Used as keys for get_theme_color/set_theme_color.
enum ui_color {
    bg,
    fg,
    text,
    text_primary,
    text_secondary,
    accent,
    border,
    frame_bg,
    sidebar_bg,
    element_button_bg,
}

