    slider_t          create_slider(string label, float64 initial, float64 minv, float64 maxv, float64 step);
    slider_icon_t     create_slider_icon(string icon, float64 initial, float64 minv, float64 maxv, float64 step);
    value_input_t     create_value_input(string label, float64 initial, float64 minv, float64 maxv, float64 step);
    options_t         create_options(string label, array<string> items, int64 selected);
    multi_options_t   create_multi_options(string label, array<string> items, int64 selected_mask);
    dropdown_t        create_dropdown(string label, array<string> items, int64 selected);
    multi_dropdown_t  create_multi_dropdown(string label, array<string> items, int64 selected_mask);
    list_t            create_list(string label, array<string> info1, array<string> info2, bool selectable, int64 selected, int64 visible_rows, bool filterable);
    inline_button_t   create_inline_button(string label, float64 width, string icon);
    inline_text_input_t create_inline_text_input(string initial, float64 width, string placeholder);
    tabs_t            create_tabs(array<string> items, int64 selected);
    keybind_t         create_keybind(string label);
    progress_bar_t    create_progress_bar(string label, float64 initial, float64 minv, float64 maxv, bool show_pct);
    spinner_t         create_spinner(string label);
    range_slider_t    create_range_slider(string label, float64 minv, float64 maxv, float64 lo, float64 hi, float64 step);
    table_t           create_table(string label, array<string> col_names, array<float64> col_widths, int64 visible_rows);
    text_input_t      create_text_input(string label, string initial, int64 max_lines);
    text_editor_t     create_text_editor(string label, string initial, int64 visible_lines, string lexer);
    colorpicker_t     create_colorpicker(string label, color initial);
}

