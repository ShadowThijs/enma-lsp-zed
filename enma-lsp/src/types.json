        {"name": "lerp",      "params": [{"name":"b","type":"vec2"},{"name":"t","type":"float64"}], "return": "vec2"},
        {"name": "rotate",    "params": [{"name":"rad","type":"float64"}], "return": "vec2", "doc": "Rotate counter-clockwise"}
