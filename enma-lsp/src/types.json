        {"name": "scale", "params": [{"name":"s","type":"float64"}], "return": "vec4"},
        {"name": "negate", "params": [], "return": "vec4"},
        {"name": "dot", "params": [{"name":"b","type":"vec4"}], "return": "float64"},
        {"name": "length", "params": [], "return": "float64"},
        {"name": "length_sq", "params": [], "return": "float64"},
        {"name": "distance", "params": [{"name":"b","type":"vec4"}], "return": "float64"},
